# Qdrant — 이 프로젝트 전용 컨테이너(포트 6335, BNK_Bot의 6333과 분리)
QDRANT_URL=http://localhost:6335
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=bnk_ops_knowledge

# LLM — Qwen via Ollama(OpenAI 호환). 엔드포인트는 BNK_Bot과 공유, 코드는 새로.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3.5-bnk

# Embedding — KURE-v1 (한국어 검색 특화, 1024-dim). 모델은 공유, 어댑터는 새로.
EMBEDDING_MODEL=nlpai-lab/KURE-v1

# 입력 자산(프로토타입 샘플)
SOURCE_DIR=examples/bank_sample
